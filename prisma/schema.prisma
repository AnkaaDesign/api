  hierarchy                 Int?
  /// Insalubridade (NR-15): grau que define o adicional (% sobre salário-mínimo).
  /// NONE = sem insalubridade. Mutuamente exclusivo com periculosidade.
  insalubrityDegree         InsalubrityDegree      @default(NONE)
  /// Periculosidade (NR-16): adicional de 30% sobre o salário-base.
  /// Mutuamente exclusivo com insalubridade.
  hazardPay                 Boolean                @default(false)
  /// Piso salarial da categoria/sindicato (Decimal). NULL = usa o salário-mínimo nacional.
  /// Reajustes são validados contra max(piso, salário-mínimo nacional).
  salaryFloor               Decimal?               @db.Decimal(10, 2)
  /// Periodicidade padrão do exame médico periódico para este cargo (meses).
  /// NULL = usa a cadência legal padrão por idade/risco.
  examPeriodicityMonths     Int?
  /// Secullum integration: Funcao.Id mapped to this Position. NULL = unmapped.
  /// Multiple positions may share the same Secullum função (N:1).
  secullumFuncaoId          Int?
  remunerations             MonetaryValue[]
  payrolls                  Payroll[]
  users                     User[]                 @relation("USER_POSITION")
  employmentContracts       EmploymentContract[]   @relation("EMPLOYMENT_CONTRACT_POSITION")
  salaryAdjustmentItems     SalaryAdjustmentItem[] @relation("SALARY_ADJUSTMENT_ITEM_POSITION")
  positionHistories         UserPositionHistory[]  @relation("USER_POSITION_HISTORY_POSITION")
  positionHistoriesPrevious UserPositionHistory[]  @relation("USER_POSITION_HISTORY_PREVIOUS_POSITION")

  @@index([name])
  @@index([hierarchy])
  @@index([secullumFuncaoId])
}

model Warning {
  id             String          @id @default(uuid())
  description    String?
  collaboratorId String
  supervisorId   String
  category       WarningCategory
  severity       WarningSeverity
  severityOrder  Int             @default(1)
  reason         String
  isActive       Boolean         @default(true)
  // Dias de suspensão (severity = SUSPENSION). CLT art. 474 limita a 30 dias corridos.
  suspensionDays Int?
  // Vínculo a uma rescisão por justa causa quando esta advertência fundamenta o desligamento.
  terminationId  String?
  hrNotes        String?
  followUpDate   DateTime
  resolvedAt     DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  collaborator   User            @relation("COLLABORATOR_WARNING", fields: [collaboratorId], references: [id])
  supervisor     User            @relation("SUPERVISOR_WARNING", fields: [supervisorId], references: [id])
  termination    Termination?    @relation("WARNING_TERMINATION", fields: [terminationId], references: [id])
  attachments    File[]          @relation("FileToWarning")
  witness        User[]          @relation("WITNESS_WARNING")

  @@index([collaboratorId])
  @@index([severityOrder])
  @@index([terminationId])
}

model Sector {
  id                     String             @id @default(uuid())
  name                   String
  privileges             SectorPrivileges   @default(BASIC)
  leaderId               String?            @unique
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
