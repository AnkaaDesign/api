// Chart-of-accounts groups (plano de contas, from CONTABILIDADE PDF). This is
// the COST/accounting axis — orthogonal to the operational item taxonomy and to
// ItemCategoryType (physical nature). Used directly on transactions, and as a
// rollup ("ponte") on item categories so a purchase lands in the right cost group.
enum AccountingType {
  SALARIOS // wages, pró-labore, aerografia labor, bonus
  DESPESAS_FIXAS // fuel, water, energy, telephony, internet, rent
  PRODUTIVO // production consumables (adesivos, fita, máscara, papel, peças, massas)
  IMPOSTO_TARIFAS // taxes, bank fees, charges
  MATERIA_PRIMA // paints, toners, thinner, removers
  INVESTIMENTO // durable goods: tools, equipment (internos/externos)
  MANUTENCAO // equipment maintenance parts/services
  COZINHA_ALIMENTACAO // kitchen / food
  EPI // PPE + uniforms
  ESCRITORIO // office / admin supplies
  APLICACAO_FINANCEIRA // financial investment moves
  ESTORNO // reversals / refunds
  LUCRO_DISTRIBUIDO // distributed profit (LD/S, LD/G)
}

model ItemCategory {
  id                    String                @id @default(uuid())
  name                  String                @unique
  type                  ItemCategoryType      @default(REGULAR)
  typeOrder             Int                   @default(1)
  // Operational taxonomy tree (production flow): a top category has parentId null
  // and its subcategories point back to it. Items attach to the LEAF (subcategory)
  // when one exists, otherwise to the top category. categoryLevel: 1=category, 2=subcategory.
  parentId              String?
  categoryLevel         Int                   @default(1)
  // Rollup to the chart of accounts (the "ponte"/grupoContabil). Inherited down the
  // tree; set on subcategories so per-item splits (e.g. Peças → PRODUTIVO vs
  // MANUTENCAO, Uniforme → EPI) land in the correct cost group.
  accountingType        AccountingType?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  parent                ItemCategory?         @relation("CATEGORY_TREE", fields: [parentId], references: [id], onDelete: SetNull)
  children              ItemCategory[]        @relation("CATEGORY_TREE")
  items                 Item[]                @relation("ITEM_CATEGORY")
  // Item-derived reconciliation categories mirror these rows (1:1) so a fiscal
  // document line tagged "Verniz" maps back to this inventory category.
  transactionCategories TransactionCategory[] @relation("ITEM_CATEGORY_TO_TX_CATEGORY")

  @@index([type, typeOrder])
  @@index([parentId])
  @@index([accountingType])
}

