// ============================================================================
// FÉRIAS (Part C)
// ============================================================================
enum VacationStatus {
  OPEN         // período aquisitivo em curso / não agendado
  SCHEDULED    // agendado (gozo futuro)
  IN_PROGRESS  // em gozo
  PAID         // pago / encerrado
  EXPIRED      // período concessivo expirou sem gozo (art. 137 — dobro)
}

// Um período aquisitivo/concessivo de férias de um vínculo. As férias são pagas
// num recibo próprio (NÃO embutidas na folha mensal).
model Vacation {
  id                          String              @id @default(uuid())
  // Nullable: ao demitir o colaborador o vínculo é desfeito (SET NULL) preservando
  // o passivo de férias para conciliação contábil (NÃO apagamos o registro).
  userId                      String?
  contractId                  String?
  // Férias coletivas: vínculo opcional ao grupo que originou este registro individual.
  groupId                     String?
  // Período aquisitivo (12 meses de trabalho que geram direito).
  acquisitiveStart            DateTime
  acquisitiveEnd              DateTime
  // Fim do período concessivo (limite legal para gozo; após isso → dobro art. 137).
  concessiveEnd               DateTime?
  // Faltas injustificadas no período aquisitivo (escala art. 130).
  unjustifiedAbsencesInPeriod Int                 @default(0)
  // Dias de direito conforme a escala (0-5→30, 6-14→24, 15-23→18, 24-32→12, >32→0).
  entitledDays                Int                 @default(30)
  status                      VacationStatus      @default(OPEN)
  statusOrder                 Int                 @default(1)
  // Abono pecuniário (venda de até 10 dias) e venda de 1/3 (abono).
  abonoPecuniarioDays         Int                 @default(0)
  soldThird                   Boolean             @default(false)
  // Base de cálculo incl. média de variáveis (HE/adicionais/bonif.) no aquisitivo.
  baseRemuneration            Decimal?            @db.Decimal(10, 2)
  oneThird                    Decimal?            @db.Decimal(10, 2)
  abonoAmount                 Decimal?            @db.Decimal(10, 2)
  inss                        Decimal?            @db.Decimal(10, 2)
  irrf                        Decimal?            @db.Decimal(10, 2)
  // Férias em dobro (gozadas após expiração do concessivo — art. 137).
  isDouble                    Boolean             @default(false)
  paymentDueDate              DateTime?
  paymentDate                 DateTime?
  notes                       String?
  // Soft-delete: registros excluídos são marcados (não removidos) para preservar
  // histórico/passivo. Todas as leituras filtram deletedAt = null.
  deletedAt                   DateTime?
  createdAt                   DateTime            @default(now())
  updatedAt                   DateTime            @updatedAt
  user                        User?               @relation("VACATION_USER", fields: [userId], references: [id], onDelete: SetNull)
  contract                    EmploymentContract? @relation("VACATION_CONTRACT", fields: [contractId], references: [id])
  group                       VacationGroup?      @relation("VACATION_GROUP", fields: [groupId], references: [id], onDelete: SetNull)
  periods                     VacationPeriod[]    @relation("VACATION_PERIOD_VACATION")

  // Unicidade do período aquisitivo por colaborador é garantida por índice ÚNICO
  // PARCIAL (WHERE deleted_at IS NULL) criado na migração SQL — permite recriar
  // após soft-delete e ignora linhas órfãs (userId NULL). Ver migration.
  @@index([userId])
  @@index([contractId])
  @@index([groupId])
  @@index([status])
  @@index([statusOrder])
  @@index([acquisitiveEnd])
  @@index([concessiveEnd])
  @@index([deletedAt])
}

// Fracionamento das férias (Reforma 2017): até 3 períodos, um ≥ 14 dias.
model VacationPeriod {
  id         String   @id @default(uuid())
  vacationId String
  startDate  DateTime
  days       Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  vacation   Vacation @relation("VACATION_PERIOD_VACATION", fields: [vacationId], references: [id], onDelete: Cascade)

  @@index([vacationId])
  @@index([startDate])
}

// Alvo das férias coletivas (CLT art. 139): toda a empresa, setores ou cargos.
enum VacationGroupType {
  ALL      // todos os colaboradores ativos
  SECTOR   // setores específicos (sectorIds)
  POSITION // cargos específicos (positionIds)
}

// Férias COLETIVAS (CLT art. 139-141). Registra-se o período coletivo PRIMEIRO;
// depois ele é "expandido" em um Vacation individual por colaborador alvo, cada
// um com seu próprio período aquisitivo e fracionamento editável.
model VacationGroup {
  id               String                @id @default(uuid())
  name             String
  type             VacationGroupType
  // Janela coletiva de referência (informativa; o aquisitivo real é por colaborador).
  acquisitiveStart DateTime
  acquisitiveEnd   DateTime
  concessiveEnd    DateTime?
  status           VacationStatus        @default(OPEN)
  statusOrder      Int                   @default(1)
  // Alvo: vazio salvo quando type=SECTOR/POSITION.
  sectorIds        String[]              @default([])
  positionIds      String[]              @default([])
  notes            String?
  deletedAt        DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  periods          VacationGroupPeriod[] @relation("VACATION_GROUP_PERIOD")
  vacations        Vacation[]            @relation("VACATION_GROUP")

  @@index([status, statusOrder])
  @@index([acquisitiveEnd])
  @@index([deletedAt])
}

// Períodos-modelo (template) compartilhados do grupo coletivo. Cada Vacation
// individual gerado herda estes períodos em seu próprio VacationPeriod[].
model VacationGroupPeriod {
  id        String        @id @default(uuid())
  groupId   String
  startDate DateTime
  days      Int
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  group     VacationGroup @relation("VACATION_GROUP_PERIOD", fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
}

// ============================================================================
// 13º SALÁRIO (Part D)
// ============================================================================
enum ThirteenthStatus {
  OPEN                 // avos acumulando
  FIRST_PAID           // 1ª parcela paga
  SECOND_PAID          // 2ª parcela paga (sem encerramento total ainda)
  PAID                 // ambas as parcelas pagas / encerrado
  CANCELLED
}

// 13º salário (gratificação natalina) de um ano para um vínculo.
model Thirteenth {
  id                    String              @id @default(uuid())
  userId                String
  contractId            String?
  year                  Int
  // Avos (≥15 dias trabalhados no mês = 1 avo; reusa a lógica de thirteenthMonths).
  avos                  Int                 @default(0)
  // Base incl. média de variáveis.
  baseRemuneration      Decimal?            @db.Decimal(10, 2)
  // 1ª parcela (50%, até 30/Nov, SEM descontos).
  firstInstallment      Decimal?            @db.Decimal(10, 2)
  firstInstallmentDate  DateTime?
  // 2ª parcela (até 20/Dez, com INSS+IRRF sobre a base EXCLUSIVA do 13º).
  secondInstallment     Decimal?            @db.Decimal(10, 2)
  secondInstallmentDate DateTime?
  inss                  Decimal?            @db.Decimal(10, 2)
  irrf                  Decimal?            @db.Decimal(10, 2)
  status                ThirteenthStatus    @default(OPEN)
  statusOrder           Int                 @default(1)
  notes                 String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  user                  User                @relation("THIRTEENTH_USER", fields: [userId], references: [id], onDelete: Cascade)
  contract              EmploymentContract? @relation("THIRTEENTH_CONTRACT", fields: [contractId], references: [id])

  @@unique([userId, year, contractId])
  @@index([userId])
  @@index([contractId])
  @@index([year])
  @@index([status])
  @@index([statusOrder])
}

// ============================================================================
// CAT — Comunicação de Acidente de Trabalho (Part E)
// ============================================================================
enum WorkAccidentReportType {
  INITIAL       // CAT inicial
  REOPENING     // CAT de reabertura
  DEATH         // CAT de óbito
}

model WorkAccidentReport {
  id           String                 @id @default(uuid())
  userId       String
  leaveId      String?                // vínculo ao afastamento (LeaveType.WORK_ACCIDENT)
  type         WorkAccidentReportType @default(INITIAL)
  catNumber    String?                // número da CAT
  emissionDate DateTime?
  accidentDate DateTime?
  description  String?
  fileId       String?                // documento da CAT
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  user         User                   @relation("WORK_ACCIDENT_REPORT_USER", fields: [userId], references: [id], onDelete: Cascade)
  leave        Leave?                 @relation("WORK_ACCIDENT_REPORT_LEAVE", fields: [leaveId], references: [id])
  file         File?                  @relation("WORK_ACCIDENT_REPORT_FILE", fields: [fileId], references: [id])

  @@index([userId])
  @@index([leaveId])
  @@index([fileId])
  @@index([emissionDate])
}

// Agenda com avisos (eventos com notificação antecipada) — módulo na fase 2
model AgendaEvent {
  id               String                @id @default(uuid())
  title            String
  description      String?
  eventDate        DateTime
  /// Dias de antecedência para notificar (ex.: [7, 1])
  notifyDaysBefore Int[]                 @default([])
  notifyOnDay      Boolean               @default(true)
  channels         NotificationChannel[] @default([])
  /// Setores-alvo das notificações (vazio + targetUserIds vazio = somente o criador)
  targetSectorIds  String[]              @default([])
  targetUserIds    String[]              @default([])
  createdById      String
  isActive         Boolean               @default(true)
  lastNotifiedAt   DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  createdBy        User                  @relation("AGENDA_EVENT_CREATED_BY", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([createdById])
  @@index([eventDate])
  @@index([isActive])
}

// Post-its pessoais (mural de lembretes) — módulo na fase 2
model Postit {
  id         String   @id @default(uuid())
  userId     String
  content    String
  color      String   @default("yellow")
  position   Int      @default(0)
  // Free-canvas placement + size (nullable; legacy/un-placed notes fall back to a grid layout)
  positionX  Float?
  positionY  Float?
  width      Float?
  height     Float?
  isArchived Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation("POSTIT_USER", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isArchived])
  @@index([position])
}

// Order payment (contas a pagar)
enum OrderPaymentStatus {
  NOT_REQUESTED
  REQUESTED
  AWAITING_PAYMENT
  PAID
}
