// Lifecycle state of a bank transaction in the reconciliation flow.
// Independent from how it got there (see ReconciliationSource) and what kind
// of payment it is (see ReconciliationCategory).
enum ReconciliationStatus {
  PENDING // not yet reconciled
  RECONCILED // fully explained (NF match or self-justifying category)
  PARTIAL // partial NF allocation (sum of matches < amount)
  IGNORED // user explicitly excluded
  DISPUTED // flagged for review
}

// Who/what drove the current state — orthogonal to status and category.
enum ReconciliationSource {
  AUTO
  MANUAL
}

// Nature of a TransactionCategory.
//   ITEM_DERIVED    — mirrors an inventory ItemCategory (Verniz, Tinta…); set
//                     automatically from a matched NF's line items. Enrichment
//                     only: never resolves a transaction on its own.
//   SERVICE         — service taxonomy for NFSe content (Contabilidade, TI…);
//                     also NF-derived enrichment.
//   TRANSACTION_ONLY — pure transaction categories with no NF (Aluguel, Folha,
//                     Pró-labore…). Assigning one (isResolving=true) reconciles
//                     the transaction.
enum TransactionCategoryKind {
  ITEM_DERIVED
  SERVICE
  TRANSACTION_ONLY
}

