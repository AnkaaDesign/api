generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Activity {
  id          String            @id @default(uuid())
  quantity    Float
  operation   ActivityOperation @default(OUTBOUND)
  userId      String?
  itemId      String
  orderId     String?
  orderItemId String?
  reason      ActivityReason    @default(PRODUCTION_USAGE)
  reasonOrder Int?              @default(2)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  item        Item              @relation("ACTIVITY_ITEM", fields: [itemId], references: [id], onDelete: Cascade)
  order       Order?            @relation("ACTIVITY_ORDER", fields: [orderId], references: [id], onDelete: Cascade)
  orderItem   OrderItem?        @relation("ACTIVITY_ORDER_ITEM", fields: [orderItemId], references: [id], onDelete: Cascade)
  user        User?             @relation("ACTIVITY_USER", fields: [userId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([userId])
  @@index([orderId])
  @@index([orderItemId])
  @@index([createdAt])
  @@index([reasonOrder])
}

model Airbrushing {
  id                    String                   @id @default(uuid())
  /// Expected (planned) start/finish dates
  startDate             DateTime?
  finishDate            DateTime?
  /// Actual start/finish timestamps (mirrors Task.startedAt/finishedAt)
  startedAt             DateTime?
  finishedAt            DateTime?
  price                 Float?
  paymentStatus         AirbrushingPaymentStatus @default(PENDING)
  /// Stamped when paymentStatus becomes PAID — windows "paid this month" on Contas a Pagar.
  paidAt                DateTime?
  status                AirbrushingStatus        @default(PENDING)
  statusOrder           Int                      @default(1)
  taskId                String
  painterId             String?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  task                  Task                     @relation("AIRBRUSHING", fields: [taskId], references: [id], onDelete: Cascade)
  painter               User?                    @relation("AIRBRUSHING_PAINTER", fields: [painterId], references: [id], onDelete: SetNull)
  artworks              Artwork[]
  budgets               File[]                   @relation("AIRBRUSHING_BUDGETS")
  invoices              File[]                   @relation("AIRBRUSHING_INVOICES")
  invoiceReimbursements File[]                   @relation("AIRBRUSHING_INVOICE_REIMBURSEMENTS")
  receipts              File[]                   @relation("AIRBRUSHING_RECEIPTS")
  reimbursements        File[]                   @relation("AIRBRUSHING_REIMBURSEMENTS")

  @@index([statusOrder])
  @@index([painterId])
}

model Artwork {
  id            String        @id @default(uuid())
  fileId        String        @unique
  status        ArtworkStatus @default(APPROVED)
  airbrushingId String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  airbrushing   Airbrushing?  @relation(fields: [airbrushingId], references: [id], onDelete: Cascade)
  file          File          @relation(fields: [fileId], references: [id], onDelete: Cascade)
  tasks         Task[]        @relation("TaskArtworks")

  @@index([fileId])
  @@index([airbrushingId])
  @@index([status])
}

model Borrow {
  id          String       @id @default(uuid())
  itemId      String
  userId      String
  quantity    Float        @default(1)
  status      BorrowStatus @default(ACTIVE)
  statusOrder Int          @default(1)
  returnedAt  DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  item        Item         @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user        User         @relation("USER_BORROW", fields: [userId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([userId])
  @@index([status, statusOrder])
}

model ChangeLog {
  id            String                    @id @default(uuid())
  entityType    ChangeLogEntityType
  entityId      String
  action        ChangeLogAction
  field         String?
  oldValue      Json?
  newValue      Json?
  reason        String?
  metadata      Json?
  userId        String?
  triggeredBy   ChangeLogTriggeredByType?
  triggeredById String?
  createdAt     DateTime                  @default(now())
  user          User?                     @relation("CHANGELOG_USER", fields: [userId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([userId])
}

model Bonus {
  id                 String          @id @default(uuid())
  userId             String
  baseBonus          Decimal         @default(0) @db.Decimal(10, 2)
  netBonus           Decimal         @default(0) @db.Decimal(10, 2)
  weightedTasks      Decimal         @default(0) @db.Decimal(10, 2)
  averageTaskPerUser Decimal         @default(0) @db.Decimal(10, 2)
  year               Int
  month              Int
  performanceLevel   Int
  // Audit trail for the salary-based logistic algorithm.
  // salaryUsed: the salary value fed into the calculation.
  // calculationVersion: BONUS_CALCULATION_VERSION at the time of save.
  // calculationParams: full JSON snapshot {salary, salaryRange, b1, config}
  // — lets historical bonuses be reproduced even if the formula evolves.
  salaryUsed         Decimal?        @db.Decimal(10, 2)
  calculationVersion String?
  calculationParams  Json?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  payrollId          String?         @unique
  payroll            Payroll?        @relation(fields: [payrollId], references: [id])
  user               User            @relation("UserBonus", fields: [userId], references: [id], onDelete: Cascade)
  bonusDiscounts     BonusDiscount[]
  bonusExtras        BonusExtra[]
  users              User[]          @relation("BonusPeriodUsers")
  tasks              Task[]          @relation("BonusTasks")

  @@unique([userId, year, month])
  @@index([userId])
  @@index([year, month])
  @@index([weightedTasks])
  @@index([averageTaskPerUser])
  @@index([netBonus])
}

// Per-period bonus calculation config. Currently holds the cumulative
// `adjustment` (reajuste) — applyPeriodAdjustment ADDS the input delta to
// this value, so apply(+5%) twice yields +10%. Both live and saved-bonus
// calculation paths read this row, which is why applies take effect even
// before any bonus has been saved for the period.
model BonusPeriodConfig {
  id         String   @id @default(uuid())
  year       Int
  month      Int
  // Stored as a fraction (0.05 = +5%) to match the runtime config shape.
  adjustment Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([year, month])
  @@index([year, month])
}

/// Company-wide target value for a metric on a single bonus period (day 26 of
/// previous month through day 25 of `month`/`year`). `sectorId` is only set for
/// per-sector metrics (e.g. COLLABORATORS_PER_SECTOR). Uniqueness on the tuple
/// (metric, year, month, sectorId) is enforced in the service layer because
/// PostgreSQL treats NULL as distinct in unique constraints.
model Goal {
  id          String     @id @default(uuid())
  metric      GoalMetric
  year        Int
  month       Int
  targetValue Decimal    @db.Decimal(15, 2)
  sectorId    String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  sector      Sector?    @relation(fields: [sectorId], references: [id], onDelete: Cascade)

  @@index([metric, year, month])
  @@index([year, month])
  @@index([sectorId])
}

enum GoalMetric {
  // Production
  TASKS_COMPLETED
  TASKS_PER_ACTIVE_USER
  PRODUCTION_AVG_PERFORMANCE
  // HR
  COLLABORATORS_PER_SECTOR
  HR_HIRES_PER_MONTH
  HR_DISMISSALS_PER_MONTH
  HR_TURNOVER_RATE
  HR_EXPERIENCE_FAILURE_RATE
  HR_ABSENTEEISM_RATE
  HR_PAYROLL_GROSS
  HR_PAYROLL_BONUSES_TOTAL
  // Finance
  INVOICES_PAID
  FINANCE_DSO_DAYS
  FINANCE_OVERDUE_AMOUNT
  FINANCE_COLLECTION_RATE
  FINANCE_QUOTES_PER_PERIOD
  FINANCE_CONVERSION_RATE
  // Order / inventory
  ORDER_COUNT_PER_PERIOD
  ORDER_TOTAL_VALUE
  INVENTORY_CONSUMPTION_VALUE
  INVENTORY_OUTBOUND_VALUE
}

model Payroll {
  id                      String            @id @default(uuid())
  baseRemuneration        Decimal           @db.Decimal(10, 2)
  year                    Int
  month                   Int
  userId                  String
  contractId              String?
  positionId              String?
  workingDaysInMonth      Int?
  workedDaysInMonth       Int?
  absenceHours            Decimal           @default(0) @db.Decimal(10, 2)
  overtime50Hours         Decimal?          @db.Decimal(10, 2)
  overtime50Amount        Decimal?          @db.Decimal(10, 2)
  overtime100Hours        Decimal?          @db.Decimal(10, 2)
  overtime100Amount       Decimal?          @db.Decimal(10, 2)
  nightHours              Decimal?          @db.Decimal(10, 2)
  nightDifferentialAmount Decimal?          @db.Decimal(10, 2)
  dsrAmount               Decimal?          @db.Decimal(10, 2)
  dsrDays                 Int?
  grossSalary             Decimal?          @db.Decimal(10, 2)
  inssBase                Decimal?          @db.Decimal(10, 2)
  inssAmount              Decimal?          @db.Decimal(10, 2)
  irrfBase                Decimal?          @db.Decimal(10, 2)
  irrfAmount              Decimal?          @db.Decimal(10, 2)
  fgtsAmount              Decimal?          @db.Decimal(10, 2)
  netSalary               Decimal?          @db.Decimal(10, 2)
  totalDiscounts          Decimal?          @db.Decimal(10, 2)
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  bonus                   Bonus?
  position                Position?           @relation(fields: [positionId], references: [id])
  user                    User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  contract                EmploymentContract? @relation("PAYROLL_CONTRACT", fields: [contractId], references: [id])
  discounts               PayrollDiscount[]

  @@unique([userId, year, month])
  @@index([userId])
  @@index([contractId])
  @@index([year, month])
  @@index([positionId])
}

model BonusDiscount {
  id               String   @id @default(uuid())
  bonusId          String
  percentage       Decimal? @db.Decimal(5, 2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  calculationOrder Int      @default(1)
  reference        String
  value            Decimal? @db.Decimal(10, 2)
  bonus            Bonus    @relation(fields: [bonusId], references: [id], onDelete: Cascade)
  suspendedTasks   Task[]

  @@index([bonusId])
  @@index([calculationOrder])
}

model BonusExtra {
  id               String   @id @default(uuid())
  bonusId          String
  percentage       Decimal? @db.Decimal(5, 2)
  value            Decimal? @db.Decimal(10, 2)
  reference        String
  calculationOrder Int      @default(1)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  bonus            Bonus    @relation(fields: [bonusId], references: [id], onDelete: Cascade)

  @@index([bonusId])
  @@index([calculationOrder])
}

model PayrollDiscount {
  id                 String              @id @default(uuid())
  percentage         Decimal?            @db.Decimal(5, 2)
  value              Decimal?            @db.Decimal(10, 2)
  reference          String
  discountType       PayrollDiscountType @default(CUSTOM)
  isPersistent       Boolean             @default(false)
  isActive           Boolean             @default(true)
  taxYear            Int?
  taxTableId         String?
  expirationDate     DateTime?
  baseValue          Decimal?            @db.Decimal(10, 2)
  /// Parcelamento (ex.: empréstimo CLT): total de parcelas contratadas
  totalInstallments  Int?
  /// Parcela corrente (1-based); avança a cada folha mensal e desativa ao exceder totalInstallments
  currentInstallment Int?
  /// Folha à qual este desconto está atrelado. NULL = desconto-mestre ancorado no colaborador
  /// (ex.: empréstimo registrado uma vez e aplicado às folhas futuras automaticamente).
  payrollId          String?
  /// Colaborador dono do desconto-mestre (quando payrollId é NULL). Permite registrar um
  /// empréstimo/desconto recorrente sem depender de uma folha pré-existente.
  userId             String?
  /// Competência inicial (YYYY-MM) a partir da qual o desconto-mestre passa a valer.
  startCompetence    String?
  /// Modalidade do empréstimo (apenas para LOAN/ADVANCE): COMPANY = empréstimo/adiantamento
  /// concedido pela própria empresa; PAYROLL_CONSIGNED = consignado em folha (banco/credor externo,
  /// descontado da folha respeitando a margem de 35%). NULL para descontos que não são empréstimo.
  loanKind           LoanKind?
  /// Banco/credor do consignado (livre). Usado quando loanKind = PAYROLL_CONSIGNED.
  lenderName         String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  payroll            Payroll?            @relation(fields: [payrollId], references: [id], onDelete: Cascade)
  user               User?               @relation("PAYROLL_DISCOUNT_USER", fields: [userId], references: [id], onDelete: Cascade)
  taxTable           TaxTable?           @relation(fields: [taxTableId], references: [id])

  @@index([payrollId])
  @@index([userId])
  @@index([discountType])
  @@index([isPersistent])
  @@index([isActive])
  @@index([taxYear])
}

model TaxTable {
  id                String               @id @default(uuid())
  taxType           TaxType
  year              Int
  effectiveFrom     DateTime
  effectiveTo       DateTime?
  calculationMethod TaxCalculationMethod @default(PROGRESSIVE)
  description       String?
  legalReference    String?
  isActive          Boolean              @default(true)
  settings          Json?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  discounts         PayrollDiscount[]
  brackets          TaxBracket[]

  @@unique([taxType, year, isActive])
  @@index([taxType, year])
  @@index([isActive])
  @@index([effectiveFrom])
}

model TaxBracket {
  id           String   @id @default(uuid())
  taxTableId   String
  bracketOrder Int
  minValue     Decimal  @db.Decimal(10, 2)
  maxValue     Decimal? @db.Decimal(10, 2)
  rate         Decimal  @db.Decimal(5, 2)
  deduction    Decimal? @db.Decimal(10, 2)
  description  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  taxTable     TaxTable @relation(fields: [taxTableId], references: [id], onDelete: Cascade)

  @@unique([taxTableId, bracketOrder])
  @@index([taxTableId])
  @@index([bracketOrder])
}

model EconomicActivity {
  id          String     @id @default(uuid())
  code        String     @unique
  description String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  customers   Customer[]

  @@index([code])
  @@index([description])
}

model Customer {
  id                   String                    @id @default(uuid())
  fantasyName          String                    @unique
  cnpj                 String?                   @unique
  cpf                  String?                   @unique
  corporateName        String?
  email                String?
  address              String?
  addressNumber        String?
  addressComplement    String?
  neighborhood         String?
  city                 String?
  state                String?
  zipCode              String?
  site                 String?
  phones               String[]
  tags                 String[]
  logoId               String?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  economicActivityId   String?
  registrationStatus   RegistrationStatus?
  stateRegistration    String?
  streetType           StreetType?
  economicActivity     EconomicActivity?         @relation(fields: [economicActivityId], references: [id])
  logo                 File?                     @relation("CUSTOMER_LOGO", fields: [logoId], references: [id])
  tasks                Task[]                    @relation("TaskCustomer")
  quoteServiceInvoices TaskQuoteService[]        @relation("QuoteServiceInvoiceToCustomer")
  quoteCustomerConfigs TaskQuoteCustomerConfig[] @relation("QuoteCustomerConfigCustomer")
  responsibles         Responsible[]             @relation("CompanyResponsibles")
  invoiceEntities      Invoice[]                 @relation("CustomerInvoiceEntities")
  externalOperations   ExternalOperation[]       @relation("CustomerExternalOperations")

  @@index([fantasyName])
  @@index([cpf])
  @@index([neighborhood])
  @@index([zipCode])
  @@index([economicActivityId])
}

model PpeSize {
  id        String         @id @default(uuid())
  shirts    ShirtSize?
  boots     BootSize?
  pants     PantsSize?
  sleeves   SleevesSize?
  mask      MaskSize?
  gloves    GlovesSize?
  rainBoots RainBootsSize?
  userId    String         @unique
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  shorts    PantsSize?
  user      User           @relation("USER_PPE_SIZE", fields: [userId], references: [id], onDelete: Cascade)
}

model PpeDelivery {
  id                 String                @id @default(uuid())
  userId             String
  itemId             String
  status             PpeDeliveryStatus     @default(PENDING)
  statusOrder        Int                   @default(1)
  quantity           Int
  reason             String?
  reviewedBy         String?
  ppeScheduleId      String?
  scheduledDate      DateTime?
  actualDeliveryDate DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  deliveryDocumentId String?
  deliveryDocument   File?                 @relation("PPE_DELIVERY_DOCUMENT", fields: [deliveryDocumentId], references: [id])
  item               Item                  @relation("PPE_DELIVERY_ITEM", fields: [itemId], references: [id], onDelete: Cascade)
  ppeSchedule        PpeDeliverySchedule?  @relation("PPE_DELIVERY_SCHEDULE", fields: [ppeScheduleId], references: [id], onDelete: Cascade)
  reviewedByUser     User?                 @relation("PPE_DELIVERY_REVIEWED_BY", fields: [reviewedBy], references: [id])
  user               User                  @relation("PPE_DELIVERY_USER", fields: [userId], references: [id], onDelete: Cascade)
  signature          PpeDeliverySignature? @relation("PPE_DELIVERY_SIGNATURE")

  @@index([userId])
  @@index([itemId])
  @@index([ppeScheduleId])
  @@index([scheduledDate])
  @@index([status, statusOrder])
  @@index([reviewedBy])
}

model PpeDeliverySignature {
  id         String      @id @default(uuid())
  deliveryId String      @unique
  delivery   PpeDelivery @relation("PPE_DELIVERY_SIGNATURE", fields: [deliveryId], references: [id], onDelete: Cascade)

  // Identity (who signed)
  signedByUserId String
  signedByUser   User   @relation("PPE_SIGNATURE_USER", fields: [signedByUserId], references: [id])
  signedByCpf    String

  // Biometric (result only — no raw biometric data per LGPD)
  biometricMethod  BiometricMethod @default(NONE)
  biometricSuccess Boolean         @default(false)

  // Device
  deviceBrand     String?
  deviceModel     String?
  deviceOs        String?
  deviceOsVersion String?
  appVersion      String?

  // Location (rounded to 4 decimal places per LGPD minimization)
  latitude         Float?
  longitude        Float?
  locationAccuracy Float?
  networkType      NetworkType @default(UNKNOWN)
  ipAddress        String?

  // Timestamps (dual — client + server for clock-skew evidence)
  clientTimestamp DateTime
  serverTimestamp DateTime @default(now())

  // Cryptographic integrity
  evidenceHash  String
  hmacSignature String

  // Signed PDF
  signedDocumentId String?
  signedDocument   File?   @relation("PPE_SIGNATURE_DOCUMENT", fields: [signedDocumentId], references: [id])

  // PAdES seal (ICP-Brasil cert applied server-side over the signed PDF)
  padesSealed      Boolean   @default(false)
  padesSealedAt    DateTime?
  certSubject      String?
  certIssuer       String?
  certSerialNumber String?
  certCnpj         String?
  certNotAfter     DateTime?

  // SHA-256 of the unsealed signed PDF (before PAdES) — shown on audit trail page
  documentSha256 String?

  // Raw evidence (for re-verification)
  evidenceJson Json

  // LGPD
  legalBasis   String  @default("NR-6/CLT Art. 166 - Comprovacao de entrega de EPI")
  consentGiven Boolean @default(true)

  createdAt DateTime @default(now())

  events PpeDeliverySignatureEvent[] @relation("PPE_SIGNATURE_EVENTS")

  @@index([signedByUserId])
  @@index([deliveryId])
}

enum PpeSignatureEventType {
  DELIVERY_CREATED
  DELIVERY_APPROVED
  DELIVERY_REJECTED
  NOTIFICATION_SENT
  NOTIFICATION_FAILED
  DOCUMENT_VIEWED
  BIOMETRIC_PROMPTED
  BIOMETRIC_SUCCEEDED
  BIOMETRIC_FAILED
  SIGNATURE_SUBMITTED
  HMAC_VALIDATED
  HMAC_REJECTED
  PADES_SEALED
  PADES_FAILED
  SIGNATURE_COMPLETED
  SIGNATURE_FAILED
  PDF_DOWNLOADED
}

model PpeDeliverySignatureEvent {
  id          String                @id @default(uuid())
  deliveryId  String
  signatureId String?
  signature   PpeDeliverySignature? @relation("PPE_SIGNATURE_EVENTS", fields: [signatureId], references: [id], onDelete: Cascade)
  type        PpeSignatureEventType
  occurredAt  DateTime              @default(now())
  actorUserId String?
  actorUser   User?                 @relation("PPE_SIGNATURE_EVENT_ACTOR", fields: [actorUserId], references: [id])
  ipAddress   String?
  userAgent   String?
  metadata    Json?

  @@index([deliveryId])
  @@index([signatureId])
  @@index([type])
  @@index([occurredAt])
}

model PpeDeliverySchedule {
  id              String                 @id @default(uuid())
  assignmentType  AssignmentType         @default(ALL)
  excludedUserIds String[]               @default([])
  includedUserIds String[]               @default([])
  frequency       ScheduleFrequency
  frequencyCount  Int                    @default(1)
  isActive        Boolean                @default(true)
  specificDate    DateTime?
  dayOfMonth      Int?
  dayOfWeek       DayOfWeek?
  month           Month?
  customMonths    Month[]
  weeklyConfigId  String?                @unique
  monthlyConfigId String?                @unique
  yearlyConfigId  String?                @unique
  nextRun         DateTime?
  lastRun         DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  name            String                 @default("Agendamento de EPI")
  autoOrders      Order[]                @relation("PPE_AUTO_ORDER")
  deliveries      PpeDelivery[]          @relation("PPE_DELIVERY_SCHEDULE")
  monthlyConfig   MonthlyScheduleConfig? @relation(fields: [monthlyConfigId], references: [id])
  weeklyConfig    WeeklyScheduleConfig?  @relation(fields: [weeklyConfigId], references: [id])
  yearlyConfig    YearlyScheduleConfig?  @relation(fields: [yearlyConfigId], references: [id])
  items           PpeScheduleItem[]      @relation("PPE_SCHEDULE_ITEMS")

  @@index([nextRun])
  @@index([isActive])
  @@index([assignmentType])
}

model PpeScheduleItem {
  id         String              @id @default(uuid())
  scheduleId String
  ppeType    PpeType
  quantity   Int                 @default(1)
  itemId     String?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  item       Item?               @relation("PPE_SCHEDULE_ITEM_ITEM", fields: [itemId], references: [id])
  schedule   PpeDeliverySchedule @relation("PPE_SCHEDULE_ITEMS", fields: [scheduleId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, ppeType, itemId])
  @@index([scheduleId])
  @@index([ppeType])
  @@index([itemId])
}

model File {
  id                                     String                    @id @default(uuid())
  filename                               String
  originalName                           String
  mimetype                               String
  path                                   String
  size                                   Int
  thumbnailUrl                           String?
  createdAt                              DateTime                  @default(now())
  updatedAt                              DateTime                  @updatedAt
  artworks                               Artwork?
  customerLogo                           Customer[]                @relation("CUSTOMER_LOGO")
  taskCuts                               Cut[]                     @relation("TASK_CUTS")
  layoutPhotos                           Layout[]                  @relation("LAYOUT_PHOTO")
  ppeDeliveryDocuments                   PpeDelivery[]             @relation("PPE_DELIVERY_DOCUMENT")
  ppeSignatureDocuments                  PpeDeliverySignature[]    @relation("PPE_SIGNATURE_DOCUMENT")
  supplierLogo                           Supplier[]                @relation("SUPPLIER_LOGO")
  configCustomerSignatures               TaskQuoteCustomerConfig[] @relation("CONFIG_CUSTOMER_SIGNATURE")
  quoteLayouts                           TaskQuote[]               @relation("QUOTE_LAYOUT")
  userAvatar                             User[]                    @relation("USER_AVATAR")
  thumbnailJob                           ThumbnailJob?
  airbrushingBudgets                     Airbrushing[]             @relation("AIRBRUSHING_BUDGETS")
  airbrushingInvoices                    Airbrushing[]             @relation("AIRBRUSHING_INVOICES")
  airbrushingInvoiceReimbursements       Airbrushing[]             @relation("AIRBRUSHING_INVOICE_REIMBURSEMENTS")
  airbrushingReceipts                    Airbrushing[]             @relation("AIRBRUSHING_RECEIPTS")
  airbrushingReimbursements              Airbrushing[]             @relation("AIRBRUSHING_REIMBURSEMENTS")
  externalOperationInvoices              ExternalOperation[]       @relation("EXTERNAL_OPERATION_INVOICES")
  externalOperationInvoiceReimbursements ExternalOperation[]       @relation("EXTERNAL_OPERATION_INVOICE_REIMBURSEMENTS")
  externalOperationReceipts              ExternalOperation[]       @relation("EXTERNAL_OPERATION_RECEIPTS")
  externalOperationReimbursements        ExternalOperation[]       @relation("EXTERNAL_OPERATION_REIMBURSEMENTS")
  warning                                Warning[]                 @relation("FileToWarning")
  observations                           Observation[]             @relation("OBSERVATIONS_FILES")
  orderBudgets                           Order[]                   @relation("ORDER_BUDGETS")
  orderInvoices                          Order[]                   @relation("ORDER_INVOICES")
  orderInvoiceReimbursements             Order[]                   @relation("ORDER_INVOICE_REIMBURSEMENTS")
