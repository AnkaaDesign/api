enum AdmissionStatus {
  DOCS_PENDING
  MEDICAL_EXAM
  CONTRACT
  REGISTRATION
  COMPLETED
  CANCELLED
}

enum AdmissionDocumentType {
  CPF
  RG
  CTPS
  PROOF_OF_RESIDENCE
  VOTER_ID
  MILITARY_CERTIFICATE
  BIRTH_MARRIAGE_CERTIFICATE
  PHOTO
  PIS
  ADMISSION_EXAM
  TRANSPORT_VOUCHER_DECLARATION
  FAMILY_SALARY_FORM
  EMPLOYMENT_CONTRACT
  TIME_BANK_AGREEMENT
  LGPD_TERM
  DRIVER_LICENSE
  OTHER
}

enum AdmissionDocumentStatus {
  PENDING
  RECEIVED
  SIGNED
  WAIVED
}

// A single employment bond (vínculo) between a person (User) and the company.
// One person can hold many over time: a rehire (readmissão) is a NEW contract while the
// prior closed one is preserved; a CLT employee who becomes terceirizado gets a new
// contract of a different employeeType. This is the source of truth for the employment
// relationship; User mirrors the current one via currentContract* fields.
model EmploymentContract {
  id              String           @id @default(uuid())
  userId          String
  sequence        Int              // ordinal vínculo for this person (1,2,3…)
  matricula       Int?             // per-vínculo registration number (eSocial matrícula)
  payrollNumber   Int?             // folha number (CLT only)
  employeeType    EmployeeType     @default(CLT)
  contractType    ContractType?    // CLT-family kind/phase; NULL for terceirizado/PJ/autônomo
  status          ContractStatus   @default(ACTIVE)
  statusOrder     Int              @default(1)
  positionId      String?
  sectorId        String?
  // Per-vínculo overrides for the position's insalubridade/periculosidade config.
  // NULL = inherit from the Position. Mutually exclusive when set (service-enforced).
  insalubrityDegreeOverride InsalubrityDegree?
  hazardPayOverride         Boolean?
  // Phase dates (CLT experiência → efetivação) — moved off User
  admissionDate   DateTime?        // vínculo start (was User.exp1StartAt / Admission.hireDate)
  exp1StartAt     DateTime?
  exp1EndAt       DateTime?
  exp2StartAt     DateTime?
  exp2EndAt       DateTime?
  effectedAt      DateTime?
  // Experiência phase (1 or 2). Normally DERIVED from exp1*/exp2* dates; this optional
  // explicit marker is for cases where date-derivation is awkward. NULL = derive from dates.
  experiencePhase Int?             // 1 | 2 | null
  // Art. 481 CLT — cláusula assecuratória do direito recíproco de rescisão; when a fixed-term
  // contract carries it, early termination follows the indeterminate regime (aviso prévio).
  hasArt481Clause Boolean          @default(false)
  // Termination
  terminationDate DateTime?        // (was User.dismissedAt)
  terminationType TerminationType?
  // Estabilidade (job-stability window) — set on return from a qualifying leave/event.
  // Blocks dismissal between stabilityStart and stabilityEnd (Part G guard).
  stabilityType   StabilityType?
  stabilityStart  DateTime?
  stabilityEnd    DateTime?
  // Terceirizado / PJ (off-folha) — the real employer / counterparty
  providerName    String?
  providerCnpj    String?
  notes           String?
  isCurrent       Boolean          @default(true) // the latest/open vínculo for this user
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  user            User             @relation("EMPLOYMENT_CONTRACT_USER", fields: [userId], references: [id], onDelete: Cascade)
  currentOfUser   User?            @relation("USER_CURRENT_CONTRACT")
  position        Position?        @relation("EMPLOYMENT_CONTRACT_POSITION", fields: [positionId], references: [id])
  sector          Sector?          @relation("EMPLOYMENT_CONTRACT_SECTOR", fields: [sectorId], references: [id])
  admission       Admission?       @relation("ADMISSION_CONTRACT")
  terminations    Termination[]    @relation("TERMINATION_CONTRACT")
  payrolls        Payroll[]        @relation("PAYROLL_CONTRACT")
  vacations       Vacation[]       @relation("VACATION_CONTRACT")
  thirteenths     Thirteenth[]     @relation("THIRTEENTH_CONTRACT")

  @@unique([userId, sequence])
  @@index([userId])
  @@index([userId, isCurrent])
  @@index([status])
  @@index([employeeType])
  @@index([positionId])
  @@index([sectorId])
}

// Grau de insalubridade (NR-15) → percentual do adicional sobre o salário-mínimo.
enum InsalubrityDegree {
  NONE  // 0%
  MIN   // 10%
  MED   // 20%
  MAX   // 40%
}

// Type of job-stability (estabilidade) window protecting against dismissal.
enum StabilityType {
  ACCIDENT    // acidentária — 12 meses após retorno (art. 118 Lei 8.213/91)
  PREGNANCY   // gestante — confirmação até 5 meses após o parto (ADCT art. 10, II, b)
  UNION       // dirigente sindical
  CIPA        // membro da CIPA
  OTHER
}

model Admission {
  id          String              @id @default(uuid())
  userId      String
  contractId  String?             @unique
  status      AdmissionStatus     @default(DOCS_PENDING)
  statusOrder Int                 @default(1)
  hireDate    DateTime?
  notes       String?
  createdById String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  user        User                @relation("ADMISSION_USER", fields: [userId], references: [id], onDelete: Cascade)
  contract    EmploymentContract? @relation("ADMISSION_CONTRACT", fields: [contractId], references: [id], onDelete: Cascade)
  createdBy   User?               @relation("ADMISSION_CREATED_BY", fields: [createdById], references: [id])
  documents   AdmissionDocument[]
  admissionExam MedicalExam?      @relation("ADMISSION_EXAM")

  @@index([userId])
  @@index([statusOrder])
  @@index([createdById])
}

model AdmissionDocument {
  id          String                  @id @default(uuid())
  admissionId String
  type        AdmissionDocumentType
  required    Boolean                 @default(true)
  status      AdmissionDocumentStatus @default(PENDING)
  fileId      String?
  expiresAt   DateTime?
  note        String?
  // ---- Assinatura eletrônica in-app (reusa o pipeline de assinatura de EPI) ----
  // Preenchidos quando um documento assinável (ex.: LGPD_TERM) é assinado no app.
  // PDF final assinado/selado (≠ fileId, que é o documento original enviado).
  signedFileId      String?
  // Quem assinou e quando (timestamps duplos cliente/servidor mantidos no JSON de evidência).
  signedByUserId    String?
  signedAt          DateTime?
  // Evidência criptográfica reusando o formato do PpeDeliverySignature.
  signatureEvidence Json?
  evidenceHash      String?
  hmacSignature     String?
  documentSha256    String?
  // Selo PAdES (ICP-Brasil) aplicado no servidor sobre o PDF assinado.
  padesSealed       Boolean   @default(false)
  padesSealedAt     DateTime?
  certSubject       String?
  certIssuer        String?
  certSerialNumber  String?
