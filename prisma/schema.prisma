enum ReconciliationAliasSource {
  MANUAL_MATCH
  AUTO_MATCH
  ADMIN_SEEDED
}

// Provenance of a learned item-category alias.
//   MANUAL      — a human set/corrected the category for this description.
//   AUTO_CODE   — derived deterministically from a uniCode hit (ground truth);
//                 safe to learn so the same product resolves later WITHOUT the
//                 code present in the text.
//   ADMIN_SEEDED — bulk-seeded.
enum ItemCategoryAliasSource {
  MANUAL
  AUTO_CODE
  ADMIN_SEEDED
}

// Shared provenance for the self-learning layer (counterparty rules, memo-token
// weights, emitter priors). Mirrors the safety posture of the alias learners:
//   MANUAL       — a human confirmed/corrected; sacred, never auto-disabled.
//   AUTO         — harvested from an accepted auto-classification/auto-match;
//                  needs sustained confirmation before it is trusted.
//   ADMIN_SEEDED — bulk-seeded (e.g. migrating the hardcoded rule maps).
enum LearnedRuleSource {
  MANUAL
  AUTO
  ADMIN_SEEDED
}

// Tier a fused classification decision lands in (persisted on CategoryDecisionLog).
enum CategoryDecisionTier {
  AUTO_APPLY
  SUGGEST
  ABSTAIN
}

model BankTransaction {
  id                    String                    @id @default(uuid())
  // Denormalized bank-account identifier columns. Together with fitId they form
  // the natural OFX dedup key — re-importing the same OFX (or overlapping ones)
  // never creates duplicate rows.
  bankCode              String
  bankName              String
  agency                String
  accountNumber         String
  ownerCnpj             String?
  fitId                 String
  postedAt              DateTime
  amount                Decimal                   @db.Decimal(14, 2)
  type                  BankTransactionType
  subtype               BankTransactionSubtype    @default(OUTROS)
  rawTrnType            String?
  memo                  String?
  counterpartyCnpjCpf   String?
  counterpartyName      String?
  runningBalance        Decimal?                  @db.Decimal(14, 2)
  // Three orthogonal axes (was a single matchStatus enum).
  reconciliationStatus  ReconciliationStatus      @default(PENDING)
  // null until the classifier has run or the user has acted.
  reconciliationSource  ReconciliationSource?
  // Whether this transaction is expected to be backed by a FiscalDocument
  // (replaces the old `category == NF` gate). The scoring matcher only runs on
  // rows with this true; everything else is resolved by its assigned
  // transaction categories. Set by the classifier.
  expectsFiscalDocument Boolean                   @default(false)
  // AUTO when the classifier or alias set the categories; MANUAL when a user did.
  categorySource        ReconciliationSource?
  classifiedAt          DateTime?
  ignoredReason         String?
  // Best candidate confidence (0-100) computed by the matcher when an auto-match
  // did NOT succeed — lets the list show "Pendente · 40%" for quick triage.
  topMatchScore         Int?
  // --- Fusion spine: SUGGEST-tier output (medium confidence, awaiting one-click
  // confirm). Non-null ⇒ the learning layer proposed this category but did NOT
  // apply it. Cleared on AUTO_APPLY or when the user categorizes by hand.
  suggestedCategoryId   String?
  suggestionConfidence  Int? // 0-100 fused confidence
  suggestionProvenance  Json? // CategorySignal[] breakdown snapshot
  bankSlipId            String?
  // Audit trail of the OFX import that created this row.
  rawFileId             String?
  uploadedById          String?
  importedAt            DateTime                  @default(now())
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  rawFile               File?                     @relation("BankTransactionFile", fields: [rawFileId], references: [id])
  uploadedBy            User?                     @relation("BankTransactionUploader", fields: [uploadedById], references: [id])
  bankSlip              BankSlip?                 @relation("BankSlipTransaction", fields: [bankSlipId], references: [id])
  matches               ReconciliationMatch[]     @relation("TransactionMatches")
  // Zero-to-many category tags. Item-derived tags (Verniz, Endurecedor) come
  // from the matched NF's line items; transaction-only tags (Aluguel) are set
  // by the classifier or by a user.
  categories            BankTransactionCategory[] @relation("TransactionCategoryTags")
  suggestedCategory     TransactionCategory?      @relation("TxSuggestedCategory", fields: [suggestedCategoryId], references: [id])
  decisionLogs          CategoryDecisionLog[]     @relation("TxDecisionLog")
  cadenceObservations   CadenceObservation[]      @relation("TxCadenceObservation")

  @@unique([bankCode, agency, accountNumber, fitId])
  @@index([postedAt])
  @@index([reconciliationStatus])
  @@index([expectsFiscalDocument])
  @@index([counterpartyCnpjCpf])
  @@index([amount])
  @@index([bankCode, accountNumber, postedAt])
  @@index([suggestedCategoryId])
  // Serves the matchAll/matchDateRange scan (PENDING + expectsFiscalDocument,
  // optionally by postedAt range) and the installment sibling lookup
  // (counterparty + PENDING + postedAt window).
  @@index([reconciliationStatus, expectsFiscalDocument, postedAt])
  @@index([counterpartyCnpjCpf, reconciliationStatus, postedAt])
}

model FiscalDocument {
  id             String                  @id @default(uuid())
  accessKey      String                  @unique
  docType        FiscalDocumentType
  operationType  FiscalDocumentOperation
  status         FiscalDocumentStatus    @default(AUTHORIZED)
  source         FiscalDocumentSource    @default(MANUAL_UPLOAD)
  issueDate      DateTime
  totalValue     Decimal                 @db.Decimal(14, 2)
  emitCnpj       String
  emitName       String?
  destCnpj       String?
  destCpf        String?
  destName       String?
  nfNumber       String?
  paymentMethods Json?
  siegId         String?
  rawXmlFileId   String?
  fetchedAt      DateTime                @default(now())
  cancelledAt    DateTime?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  // --- Rich data extracted from the source XML (backfilled from rawXmlFile) ---
  // Document identification (NFe ide block / NFSe header)
  series                    String? // ide.serie
  model                     String? // ide.mod (55=NFe, 65=NFCe, 57=CTe)
  naturezaOperacao          String? // ide.natOp
  // infNFe/infAdic/infCpl — Informações Complementares de Interesse do Contribuinte
  infCpl                    String?   @db.Text
  // Authorization protocol (protNFe.infProt / NFSe protocol)
  protocolNumber            String? // nProt
  authorizationDate         DateTime? // dhRecbto — when SEFAZ authorized
  cStat                     String? // protocol status code (100=authorized, 101=cancelled, ...)
  xMotivo                   String? // protocol status reason
  // True when issueDate could not be parsed from the XML and was inferred.
  dateInferred              Boolean   @default(false)
  // Emitente / Destinatário extra data (addresses/IE/email stored as JSON blobs:
  // { logradouro, numero, complemento, bairro, municipio, uf, cep, fone })
  emitIE                    String?
  emitAddress               Json?
  destIE                    String?
  destEmail                 String?
  destAddress               Json?
  // NFe ICMSTot totals breakdown: { vBC, vICMS, vICMSDeson, vProd, vFrete,
  // vSeg, vDesc, vOutro, vST, vIPI, vPIS, vCOFINS, vNF, vTotTrib }
  totals                    Json?
  // NFSe service-specific fields (null for NFe/NFCe/CTe)
  issValue                  Decimal?  @db.Decimal(14, 2)
  issRetained               Boolean?
  issRate                   Decimal?  @db.Decimal(7, 4) // aliquota %
  baseCalculo               Decimal?  @db.Decimal(14, 2)
  valorLiquido              Decimal?  @db.Decimal(14, 2)
  valorServicos             Decimal?  @db.Decimal(14, 2) // gross (before retenções)
  codigoTributacaoMunicipio String?
  municipioPrestacao        String? // IBGE code or name
  itemListaServico          String? // ABRASF service list code

  rawXmlFile File?                     @relation("FiscalDocXml", fields: [rawXmlFileId], references: [id])
  matches    ReconciliationMatch[]     @relation("DocumentMatches")
  items      FiscalDocumentItem[]
  orderCodes FiscalDocumentOrderCode[]

  @@index([docType])
  @@index([operationType])
  @@index([issueDate])
  @@index([emitCnpj, issueDate])
  @@index([destCnpj, issueDate])
  @@index([status])
}

// Line items / services for a FiscalDocument. NFe carries product lines
// (`det[]`), NFSe carries a single service line (`Servico`). We persist these
// in their own table so the NF detail modal can render them without parsing
// raw XML on every request. Re-imports of the same XML replace existing items
// (delete-then-create) so the list stays consistent with the source.
model FiscalDocumentItem {
  id                 String                @id @default(uuid())
  fiscalDocumentId   String
  code               String? // NFe: cProd; NFSe: ItemListaServico / cServ
  description        String                @db.Text
  quantity           Decimal?              @db.Decimal(15, 4)
  unit               String?
  unitValue          Decimal?              @db.Decimal(15, 4)
  totalValue         Decimal               @db.Decimal(15, 2)
  // Fiscal classification extracted from the source XML (NFe det/prod + imposto)
  ncm                String? // prod.NCM
  cfop               String? // prod.CFOP
  cest               String? // prod.CEST
  ean                String? // prod.cEAN
  cst                String? // ICMS CST / CSOSN
  discount           Decimal?              @db.Decimal(15, 2) // prod.vDesc
  freight            Decimal?              @db.Decimal(15, 2) // prod.vFrete
  // Per-item tax breakdown: { icms:{vBC,pICMS,vICMS,cst}, ipi:{...},
  // pis:{...}, cofins:{...} } — null for NFSe service lines.
  taxes              Json?
  // Cached result of the fuzzy item-category classifier (description/code →
  // ItemCategory-backed TransactionCategory). Null until the classifier runs
  // or when no category clears the confidence threshold.
  categoryId         String?
  categoryConfidence Int? // 0-100, fuzzy match score
  categorySource     ReconciliationSource?
  createdAt          DateTime              @default(now())
  fiscalDocument     FiscalDocument        @relation(fields: [fiscalDocumentId], references: [id], onDelete: Cascade)
  category           TransactionCategory?  @relation("FiscalItemCategory", fields: [categoryId], references: [id])

  @@index([fiscalDocumentId])
  @@index([categoryId])
}

// Purchase-order codes ("#Ped:" tokens) parsed from FiscalDocument.infCpl.
// Many-to-many in practice: one NF may list several order codes (consolidated
// invoice), and one order spans several NFs (split deliveries). Stored as a
// normalized join so the matcher can do the reverse lookup "all NFs for order X"
// as an indexed `code` seek when summing an order's NFs into a single payment.
// Refreshed delete-then-create on re-import, mirroring FiscalDocumentItem.
model FiscalDocumentOrderCode {
  id               String   @id @default(uuid())
  fiscalDocumentId String
  code             String // raw "#Ped:" code from infCpl (e.g. "C34673")
  createdAt        DateTime @default(now())

  fiscalDocument FiscalDocument @relation(fields: [fiscalDocumentId], references: [id], onDelete: Cascade)

  @@unique([fiscalDocumentId, code])
  @@index([code])
  @@index([fiscalDocumentId])
}

model ReconciliationMatch {
  id               String                  @id @default(uuid())
  transactionId    String
  fiscalDocumentId String?
  bankSlipId       String?
  allocatedAmount  Decimal                 @db.Decimal(14, 2)
  matchType        ReconciliationMatchType
  confidenceScore  Int                     @default(100)
  matchedByUserId  String?
  notes            String?
  matchedAt        DateTime                @default(now())
  reversedAt       DateTime?
  reversedById     String?
  transaction      BankTransaction         @relation("TransactionMatches", fields: [transactionId], references: [id], onDelete: Cascade)
  fiscalDocument   FiscalDocument?         @relation("DocumentMatches", fields: [fiscalDocumentId], references: [id], onDelete: Restrict)
  bankSlip         BankSlip?               @relation("BankSlipMatches", fields: [bankSlipId], references: [id])
  matchedBy        User?                   @relation("MatchedBy", fields: [matchedByUserId], references: [id])

  @@unique([transactionId, fiscalDocumentId])
  @@index([transactionId])
  @@index([fiscalDocumentId])
  @@index([bankSlipId])
  @@index([matchType])
}

model ReconciliationRun {
  id            String                   @id @default(uuid())
  trigger       ReconciliationRunTrigger
  status        ReconciliationRunStatus  @default(RUNNING)
  dateStart     DateTime?
  dateEnd       DateTime?
  triggeredById String?
  startedAt     DateTime                 @default(now())
  finishedAt    DateTime?
  stats         Json?
  errorMessage  String?
  triggeredBy   User?                    @relation("ReconciliationRunTriggers", fields: [triggeredById], references: [id])

  @@index([status])
  @@index([startedAt])
}

// Learned (memoFingerprint → counterparty CNPJ/CPF) pairs from confirmed
// reconciliation matches. Lets the matcher recover counterparty identity for
// transactions whose OFX memo does not carry a parseable CNPJ. Aliases never
// auto-match alone — they feed into the existing CNPJ score, then the same
// 90-threshold / 8-point runner-up gate applies.
model ReconciliationAlias {
  id                  String                    @id @default(uuid())
  memoFingerprint     String
  counterpartyCnpjCpf String
  txType              BankTransactionType
  source              ReconciliationAliasSource
  // Optional category to remember. When set, the classifier applies this
  // category to future transactions matching the same alias key (e.g.
  // Sergio's CPF → Pró-labore). Null aliases only feed the NF scoring path.
  categoryId          String?
  category            TransactionCategory?      @relation("AliasCategory", fields: [categoryId], references: [id])
  confirmedCount      Int                       @default(1)
  rejectedCount       Int                       @default(0)
  firstObservedAt     DateTime                  @default(now())
  lastConfirmedAt     DateTime                  @default(now())
  disabledAt          DateTime?
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt

  @@unique([memoFingerprint, counterpartyCnpjCpf, txType])
  @@index([memoFingerprint, txType])
  @@index([counterpartyCnpjCpf])
  @@index([disabledAt])
  @@index([categoryId])
}

// Unified reconciliation taxonomy. Merges three kinds (see
// TransactionCategoryKind): item-derived categories mirrored 1:1 from
// ItemCategory, service categories for NFSe content, and pure transaction-only
// categories the user creates (Aluguel etc.). Replaces the old
// ReconciliationCategory enum so the list can grow at runtime.
enum RecurrenceKind {
  FIXED
  VARIABLE
}

/// One settlement record per payroll competence month (year+month). Folha is
/// paid as a single batch, so settlement is tracked at the month level (never
/// per-employee, for privacy). Absence of a row = not yet paid.
model PayrollMonthSettlement {
  id        String    @id @default(uuid())
  year      Int
  month     Int
  amount    Decimal?  @db.Decimal(12, 2)
  paidAt    DateTime?
  paidById  String?
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([year, month])
  @@index([year, month])
}

model TransactionCategory {
  id             String                  @id @default(uuid())
  name           String                  @unique
  // URL/code-safe stable key. Item-derived/service/seeded rows have fixed slugs
  // the classifier resolves against; user-created rows get a slugified name.
  slug           String                  @unique
  kind           TransactionCategoryKind
  // Set for ITEM_DERIVED rows — the inventory category this mirrors.
  itemCategoryId String?
  // When true, assigning this category resolves the transaction (RECONCILED)
  // without needing an NF. True for TRANSACTION_ONLY; false for the NF-derived
  // kinds. Replaces the old hardcoded SELF_JUSTIFYING_CATEGORIES set.
  isResolving    Boolean                 @default(false)
  // Marks a recurring monthly obligation (rent, payroll…). Drives the monthly
  // payables view. A flag only — amounts are read from the actual transactions.
  isRecurring    Boolean                 @default(false)
  // For recurring categories: FIXED = known monthly amount (fixedAmount on the
  // statutory dueDayOfMonth); VARIABLE = estimated from the 3-month average.
  recurrenceKind RecurrenceKind          @default(VARIABLE)
  fixedAmount    Decimal?                @db.Decimal(12, 2)
  dueDayOfMonth  Int?
  color          String?
  sortOrder      Int                     @default(0)
  isActive       Boolean                 @default(true)
  // Chart-of-accounts rollup (plano de contas). For ITEM_DERIVED rows this mirrors
  // the linked ItemCategory.accountingType; for TRANSACTION_ONLY/SERVICE rows it's
  // the cost group the transaction lands in (Folha→SALARIOS, Tributo→IMPOSTO…).
  accountingType AccountingType?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  itemCategory          ItemCategory?              @relation("ITEM_CATEGORY_TO_TX_CATEGORY", fields: [itemCategoryId], references: [id])
  transactionTags       BankTransactionCategory[]  @relation("CategoryToTransactionTags")
  fiscalDocumentItems   FiscalDocumentItem[]       @relation("FiscalItemCategory")
  aliases               ReconciliationAlias[]      @relation("AliasCategory")
  itemCategoryAliases   ItemCategoryAlias[]        @relation("ItemCategoryAliasCategory")
  counterpartyRules     CounterpartyCategoryRule[] @relation("CounterpartyRuleCategory")
  memoTokenWeights      MemoTokenWeight[]          @relation("MemoTokenCategory")
  emitterPriors         EmitterCategoryPrior[]     @relation("EmitterPriorCategory")
  cadences              CounterpartyCadence[]      @relation("CadenceCategory")
  suggestedTransactions BankTransaction[]          @relation("TxSuggestedCategory")

  @@index([kind])
  @@index([itemCategoryId])
  @@index([isRecurring])
  @@index([isActive])
  @@index([accountingType])
}

// Learned (NF line description fingerprint → category) pairs — the categorizer's
// equivalent of ReconciliationAlias. Lets past categorizations (deterministic
// uniCode hits and human corrections) drive future auto-categorization of
// lines whose text alone is ambiguous. Consulted right after the uniCode tier,
// ahead of fuzzy/keyword heuristics.
model ItemCategoryAlias {
  id                     String                  @id @default(uuid())
  // descriptionFingerprint(): sorted, stoplisted token key of the NF line.
  descriptionFingerprint String
  categoryId             String
  source                 ItemCategoryAliasSource
  confirmedCount         Int                     @default(1)
  rejectedCount          Int                     @default(0)
  firstObservedAt        DateTime                @default(now())
  lastConfirmedAt        DateTime                @default(now())
  disabledAt             DateTime?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  category               TransactionCategory     @relation("ItemCategoryAliasCategory", fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([descriptionFingerprint, categoryId])
  @@index([descriptionFingerprint])
  @@index([categoryId])
  @@index([disabledAt])
}

// Many-to-many tag between a transaction and the taxonomy. A single NF
// transaction can carry several item-derived categories (Verniz + Endurecedor),
// each with its own provenance, confidence and proportional amount split.
model BankTransactionCategory {
  id                      String               @id @default(uuid())
  transactionId           String
  categoryId              String
  // AUTO when the fuzzy classifier set it; MANUAL when a user did.
  source                  ReconciliationSource @default(AUTO)
  // 0-100 fuzzy confidence for AUTO item-derived tags; null for MANUAL.
  confidence              Int?
  // Proportional share of the transaction amount attributed to this category
  // (sum of the matched NF line items' totalValue for this category, scaled to
  // the transaction). Null for transaction-only tags.
  allocatedAmount         Decimal?             @db.Decimal(14, 2)
  // The NF line item this tag was derived from (provenance for AUTO tags).
  derivedFromFiscalItemId String?
  assignedById            String?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt

  transaction BankTransaction     @relation("TransactionCategoryTags", fields: [transactionId], references: [id], onDelete: Cascade)
  category    TransactionCategory @relation("CategoryToTransactionTags", fields: [categoryId], references: [id], onDelete: Restrict)
  assignedBy  User?               @relation("TransactionCategoryAssignedBy", fields: [assignedById], references: [id])

  @@unique([transactionId, categoryId])
  @@index([transactionId])
  @@index([categoryId])
  @@index([categoryId, source])
}

// ===========================================================================
// Self-learning layer — counterparty / memo-token / NF-emitter learners + the
// fusion-decision audit log. All learners mirror ReconciliationAlias safety:
// single AUTO attestation never bootstraps (confidence 0), MANUAL is never
// auto-disabled, soft-disable via disabledAt after sustained rejections.
// ===========================================================================

// Learned (counterparty CPF/CNPJ → category), memo-independent. The DB-backed,
// learnable replacement for the hardcoded COUNTERPARTY_CATEGORY_RULES map: a CPF
// resolves to exactly one category per direction (txType), regardless of how the
// bank formats the memo (pró-labore draws, rent PIX paid to a CPF, …).
model CounterpartyCategoryRule {
  id                  String              @id @default(uuid())
  // digits-only CPF (11) or CNPJ (14).
  counterpartyCnpjCpf String
  // Same CPF can mean different things on DEBIT vs CREDIT.
  txType              BankTransactionType
  categoryId          String
  category            TransactionCategory @relation("CounterpartyRuleCategory", fields: [categoryId], references: [id], onDelete: Cascade)
  source              LearnedRuleSource
  confirmedCount      Int                 @default(1)
  rejectedCount       Int                 @default(0)
  firstObservedAt     DateTime            @default(now())
  lastConfirmedAt     DateTime            @default(now())
  disabledAt          DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  // Identity→category is a function: one winning category per (cnpj, txType). A
  // different category is a contested update handled in service code, not a row.
  @@unique([counterpartyCnpjCpf, txType])
  @@index([counterpartyCnpjCpf])
  @@index([categoryId])
  @@index([disabledAt])
}

// Learned (counterparty NAME fingerprint → CPF/CNPJ identity). When an OFX memo
// carries a payee name but no parseable document, this recovers the identity,
// which then unlocks CounterpartyCategoryRule + the NF scoring path.
model CounterpartyProfile {
  id                  String            @id @default(uuid())
  // nameFingerprint(counterpartyName): sorted, stoplisted token key.
  nameFingerprint     String
  counterpartyCnpjCpf String // digits-only resolved identity
  displayName         String? // last-seen raw name, for the admin UI
  source              LearnedRuleSource
  confirmedCount      Int               @default(1)
  rejectedCount       Int               @default(0)
  firstObservedAt     DateTime          @default(now())
  lastConfirmedAt     DateTime          @default(now())
  disabledAt          DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  // One row per (nameFp, cnpj); two CNPJs for one name → two rows → the
  // ambiguity guard in resolveIdentity() decides whether to answer.
  @@unique([nameFingerprint, counterpartyCnpjCpf])
  @@index([nameFingerprint])
  @@index([counterpartyCnpjCpf])
  @@index([disabledAt])
}

// Learned token-vote model for transaction memos → TRANSACTION_ONLY categories.
// One row per (token, categoryId). Effective vote = max(0, weight - negWeight),
// so a re-categorization decays the wrong token without erasing its history.
// Generalizes where exact-fingerprint aliases can't (one DARF teaches all DARFs).
model MemoTokenWeight {
  id              String              @id @default(uuid())
  token           String // normalized memo token (memoLearnTokens())
  categoryId      String
  category        TransactionCategory @relation("MemoTokenCategory", fields: [categoryId], references: [id], onDelete: Cascade)
  source          LearnedRuleSource   @default(AUTO)
  weight          Float               @default(0)
  negWeight       Float               @default(0)
  confirmedCount  Int                 @default(0)
  rejectedCount   Int                 @default(0)
  firstObservedAt DateTime            @default(now())
  lastConfirmedAt DateTime            @default(now())
  disabledAt      DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@unique([token, categoryId])
  @@index([token])
  @@index([categoryId])
  @@index([disabledAt])
}

// Global document frequency per memo token (across ALL categories), so the IDF
// down-weight of ubiquitous tokens (pix/ted/pagamento) is O(1) at score time.
model MemoTokenStat {
  id            String   @id @default(uuid())
  token         String   @unique
  categoryCount Int      @default(0) // distinct categories this token votes for
  totalCount    Int      @default(0)
  updatedAt     DateTime @updatedAt

  @@index([token])
}

// Learned (emitter CNPJ → transaction category) prior, aggregated across every
// confirmed NF from a given emitter — predicts the category BEFORE line-level
// classification. Purity is derived across sibling rows sharing an emitterCnpj.
model EmitterCategoryPrior {
  id              String                  @id @default(uuid())
  emitterCnpj     String // full digits-only CNPJ
  emitterRoot     String // first 8 digits — root fallback
  categoryId      String
  category        TransactionCategory     @relation("EmitterPriorCategory", fields: [categoryId], references: [id], onDelete: Cascade)
  categoryKind    TransactionCategoryKind // weight ITEM_DERIVED/SERVICE vs TRANSACTION_ONLY
  source          LearnedRuleSource       @default(AUTO)
  confirmedCount  Int                     @default(1)
  rejectedCount   Int                     @default(0)
  firstObservedAt DateTime                @default(now())
  lastConfirmedAt DateTime                @default(now())
  disabledAt      DateTime?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@unique([emitterCnpj, categoryId])
  @@index([emitterCnpj])
  @@index([emitterRoot])
  @@index([categoryId])
  @@index([disabledAt])
}

// Per-(counterparty, category) cadence + rolling expected amount. Learned from
// the spacing/amounts of confirmed transactions; drives the learned-recurring
// flag, the forecast read model and the per-period anomaly band.
model CounterpartyCadence {
  id                 String               @id @default(uuid())
  // CNPJ/CPF (digits) when known, else memoFingerprint.
  counterpartyKey    String
  counterpartyLabel  String?
  categoryId         String
  category           TransactionCategory  @relation("CadenceCategory", fields: [categoryId], references: [id], onDelete: Cascade)
  sampleCount        Int                  @default(0)
  meanPeriodDays     Float? // EWMA inter-arrival gap
  periodVarianceDays Float?
  expectedAmount     Decimal?             @db.Decimal(14, 2) // EWMA abs amount
  amountVariance     Float?
  lastSeenAt         DateTime?
  lastAmount         Decimal?             @db.Decimal(14, 2)
  // Learned recurring flag — distinct from TransactionCategory.isRecurring
  // (which stays the manual/global flag).
  isLearnedRecurring Boolean              @default(false)
  periodCv           Float? // coefficient of variation of the period
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  observations       CadenceObservation[] @relation("CadenceObservations")

  @@unique([counterpartyKey, categoryId])
  @@index([categoryId])
  @@index([isLearnedRecurring])
  @@index([lastSeenAt])
}

// Append-only ledger of each occurrence feeding a CounterpartyCadence. Lets us
// recompute stats deterministically and dedupe a re-categorized tx so its amount
// is never double-counted into the rolling mean.
model CadenceObservation {
  id            String              @id @default(uuid())
  cadenceId     String
  transactionId String
  occurredAt    DateTime
  amount        Decimal             @db.Decimal(14, 2)
  createdAt     DateTime            @default(now())
  cadence       CounterpartyCadence @relation("CadenceObservations", fields: [cadenceId], references: [id], onDelete: Cascade)
  transaction   BankTransaction     @relation("TxCadenceObservation", fields: [transactionId], references: [id], onDelete: Cascade)

  // One observation per (cadence, transaction): re-categorizing must not add a
  // second data point.
  @@unique([cadenceId, transactionId])
  @@index([cadenceId])
  @@index([transactionId])
}

// Append-only audit of every fusion decision (AUTO_APPLY/SUGGEST/ABSTAIN) and
// every correction. Powers the explain() ("why was this categorized?") endpoint
// and is the source of truth for which learned rows to decay on a correction.
model CategoryDecisionLog {
  id            String               @id @default(uuid())
  transactionId String
  transaction   BankTransaction      @relation("TxDecisionLog", fields: [transactionId], references: [id], onDelete: Cascade)
  tier          CategoryDecisionTier
  categoryId    String?
  confidence    Int // 0-100
  // Full CategorySignal[] at decision time (winners + conflicts + losers).
  breakdown     Json
  // Winning signals only, denormalized for fast reversal fan-out.
  winners       Json
  // 'CLASSIFY' | 'CORRECTION' | 'REPLAY'
  event         String
  createdAt     DateTime             @default(now())

  @@index([transactionId, createdAt])
  @@index([tier])
}

// =====================
// Inventory Analytics
// =====================

model ConsumptionSnapshot {
  id                    String   @id @default(uuid())
  itemId                String
  year                  Int
  month                 Int // 0-indexed (0 = January, 11 = December)
  totalConsumption      Float    @default(0)
  consumptionCount      Int      @default(0) // Number of outbound activities
  normalizedConsumption Float    @default(0) // Adjusted for working days
  workingDays           Int      @default(22)
  seasonalFactor        Float    @default(1.0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([itemId, year, month])
  @@index([itemId])
  @@index([year, month])
}

// =====================
// Skill Assessment Models
// =====================
// Domain: a Skill (e.g. Comportamental / Segurança do Trabalho / Produtividade)
// contains one or more Topics (the assessable items, e.g. "Disciplina e
// cumprimento de regras"). Each Topic has exactly six TopicLevels (score 0..5)
// with bespoke level NAMES per topic (e.g. score 5 = "Referência" for one
// topic, "Estabilizador" for another, "Guardião" for another). An Assessment
// is a campaign with start/end dates targeting selected Sectors and Topics;
// when opened, AssessmentEntry rows are generated for each evaluatee × their
// sector leader (evaluator), each carrying AssessmentResponse rows (one per
// selected Topic).

enum AssessmentStatus {
  DRAFT
  OPEN
  CLOSED
  CANCELLED
}

enum AssessmentEntryStatus {
  PENDING
  IN_PROGRESS
  SUBMITTED
}

model Skill {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  order       Int
  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  topics           Topic[]
  assessmentSkills AssessmentSkill[]

  @@index([order])
  @@index([isActive])
  @@index([deletedAt])
}

model Topic {
  id               String    @id @default(uuid())
  skillId          String
  order            Int
  title            String
  description      String
  counterBehaviors String
  isActive         Boolean   @default(true)
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  skill            Skill                @relation(fields: [skillId], references: [id])
  levels           TopicLevel[]
  assessmentTopics AssessmentTopic[]
  responses        AssessmentResponse[]

  @@unique([skillId, order])
  @@index([skillId])
  @@index([deletedAt])
}

model TopicLevel {
  id          String   @id @default(uuid())
  topicId     String
  score       Int
  name        String
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  topic Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([topicId, score])
  @@index([topicId])
}

model Assessment {
  id          String           @id @default(uuid())
  name        String
  description String?
  periodStart DateTime
  periodEnd   DateTime
  status      AssessmentStatus @default(DRAFT)
  createdById String
  deletedAt   DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  createdBy User               @relation("ASSESSMENT_CREATED_BY", fields: [createdById], references: [id])
  sectors   AssessmentSector[]
  skills    AssessmentSkill[]
  topics    AssessmentTopic[]
  entries   AssessmentEntry[]

  @@index([status])
  @@index([periodStart, periodEnd])
  @@index([createdById])
  @@index([deletedAt])
}

model AssessmentSector {
  assessmentId String
  sectorId     String
  /// Optional per-sector appraiser override. When null, openAssessment falls
  /// back to Sector.leaderId. Allows campaigns to cover sectors without a
  /// designated leader, or to substitute the leader on a per-campaign basis.
  appraiserId  String?

  assessment Assessment                  @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  sector     Sector                      @relation(fields: [sectorId], references: [id])
  appraiser  User?                       @relation("ASSESSMENT_SECTOR_APPRAISER", fields: [appraiserId], references: [id])
  evaluatees AssessmentSectorEvaluatee[]

  @@id([assessmentId, sectorId])
  @@index([assessmentId])
  @@index([sectorId])
  @@index([appraiserId])
}

/// Explicit per-sector evaluatee list for a campaign.
/// When openAssessment runs, only users listed here become AssessmentEntry rows
/// (one entry per evaluatee, evaluator = effective appraiser of the sector).
model AssessmentSectorEvaluatee {
  assessmentId String
  sectorId     String
  userId       String

  assessmentSector AssessmentSector @relation(fields: [assessmentId, sectorId], references: [assessmentId, sectorId], onDelete: Cascade)
  user             User             @relation("ASSESSMENT_SECTOR_EVALUATEE", fields: [userId], references: [id])

  @@id([assessmentId, sectorId, userId])
  @@index([assessmentId])
  @@index([sectorId])
  @@index([userId])
}

model AssessmentSkill {
  assessmentId String
  skillId      String

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  skill      Skill      @relation(fields: [skillId], references: [id])

  @@id([assessmentId, skillId])
  @@index([assessmentId])
  @@index([skillId])
}

model AssessmentTopic {
  assessmentId String
  topicId      String

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  topic      Topic      @relation(fields: [topicId], references: [id])

  @@id([assessmentId, topicId])
  @@index([assessmentId])
  @@index([topicId])
}

model AssessmentEntry {
  id           String                @id @default(uuid())
  assessmentId String
  evaluateeId  String
  evaluatorId  String
  status       AssessmentEntryStatus @default(PENDING)
  startedAt    DateTime?
  submittedAt  DateTime?
  notes        String?
  deletedAt    DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  assessment Assessment           @relation(fields: [assessmentId], references: [id])
  evaluatee  User                 @relation("ASSESSMENT_ENTRY_EVALUATEE", fields: [evaluateeId], references: [id])
  evaluator  User                 @relation("ASSESSMENT_ENTRY_EVALUATOR", fields: [evaluatorId], references: [id])
  responses  AssessmentResponse[]

  @@unique([assessmentId, evaluateeId])
  @@index([assessmentId])
  @@index([evaluateeId])
  @@index([evaluatorId])
  @@index([status])
  @@index([deletedAt])
}

model AssessmentResponse {
  id            String   @id @default(uuid())
  entryId       String
  topicId       String
  score         Int
  justification String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  entry AssessmentEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  topic Topic           @relation(fields: [topicId], references: [id])

  @@unique([entryId, topicId])
  @@index([entryId])
  @@index([topicId])
}

// =====================
// Questionnaire Models
// =====================
// A SELF-FILL questionnaire domain, structurally mirroring the skill-assessment
// domain but completely separate so the skill engine is never touched. Domain:
// a QuestionnaireGroup (the "main group", e.g. "Satisfação no trabalho")
// contains QuestionnaireQuestions (the assessable items, with a description),
// each with one or more QuestionnaireOptions (the possible answers, carrying a
// numeric `value` — by convention 0..5 so the shared ScoreBadge palette
// applies). A Questionnaire is a campaign with start/end dates targeting
// selected collaborators (or ALL users) and Questions; when opened, one
// QuestionnaireEntry is generated PER targeted user. Unlike an assessment the
// respondent fills it FOR THEMSELVES — there is no separate evaluator.

enum QuestionnaireStatus {
  DRAFT
  OPEN
  CLOSED
  CANCELLED
}

enum QuestionnaireEntryStatus {
  PENDING
  IN_PROGRESS
  SUBMITTED
}

model QuestionnaireGroup {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  order       Int
  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  questions QuestionnaireQuestion[]

  @@index([order])
  @@index([isActive])
  @@index([deletedAt])
}

model QuestionnaireQuestion {
  id          String    @id @default(uuid())
  groupId     String
  order       Int
  title       String
  description String
  helpText    String?
  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  group   QuestionnaireGroup          @relation(fields: [groupId], references: [id])
  options QuestionnaireOption[]
  links   QuestionnaireQuestionLink[]
  answers QuestionnaireAnswer[]

  @@unique([groupId, order])
  @@index([groupId])
  @@index([deletedAt])
}

model QuestionnaireOption {
  id          String   @id @default(uuid())
  questionId  String
  order       Int
  value       Int
  label       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  question QuestionnaireQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, order])
  @@index([questionId])
}

model Questionnaire {
  id             String              @id @default(uuid())
  name           String
  description    String?
  periodStart    DateTime
  periodEnd      DateTime
  status         QuestionnaireStatus @default(DRAFT)
  createdById    String
  /// When true, opening generates an entry for every active user. When false,
  /// only the explicitly targeted collaborators (targetUsers) get an entry.
  targetAllUsers Boolean             @default(false)
  /// Incognito mode. When true, responses are NEVER attributable to a respondent
  /// via the API: per-respondent admin review is blocked, respondent identity is
  /// stripped from every payload, and admins only ever see anonymized aggregate
  /// results. The respondent↔answers link still exists in the DB (for delivery,
  /// dedup and resume) but is never exposed. Locked once the questionnaire opens.
  isAnonymous    Boolean             @default(false)
  deletedAt      DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  createdBy   User                        @relation("QUESTIONNAIRE_CREATED_BY", fields: [createdById], references: [id])
  targetUsers QuestionnaireUser[]
  questions   QuestionnaireQuestionLink[]
  entries     QuestionnaireEntry[]

  @@index([status])
  @@index([periodStart, periodEnd])
  @@index([createdById])
  @@index([deletedAt])
}

/// Explicit per-campaign target collaborators. When openQuestionnaire runs and
/// targetAllUsers is false, one QuestionnaireEntry is generated per user listed here.
model QuestionnaireUser {
  questionnaireId String
  userId          String

  questionnaire Questionnaire @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
  user          User          @relation("QUESTIONNAIRE_TARGET_USER", fields: [userId], references: [id])

  @@id([questionnaireId, userId])
  @@index([questionnaireId])
  @@index([userId])
}

model QuestionnaireQuestionLink {
  questionnaireId String
  questionId      String

  questionnaire Questionnaire         @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
  question      QuestionnaireQuestion @relation(fields: [questionId], references: [id])

  @@id([questionnaireId, questionId])
  @@index([questionnaireId])
  @@index([questionId])
}

model QuestionnaireEntry {
  id              String                   @id @default(uuid())
  questionnaireId String
  respondentId    String
  status          QuestionnaireEntryStatus @default(PENDING)
  startedAt       DateTime?
  submittedAt     DateTime?
  notes           String?
  deletedAt       DateTime?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  questionnaire Questionnaire         @relation(fields: [questionnaireId], references: [id])
  respondent    User                  @relation("QUESTIONNAIRE_ENTRY_RESPONDENT", fields: [respondentId], references: [id])
  answers       QuestionnaireAnswer[]

  @@unique([questionnaireId, respondentId])
  @@index([questionnaireId])
  @@index([respondentId])
  @@index([status])
  @@index([deletedAt])
}

model QuestionnaireAnswer {
  id         String   @id @default(uuid())
  entryId    String
  questionId String
  value      Int
  comment    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  entry    QuestionnaireEntry    @relation(fields: [entryId], references: [id], onDelete: Cascade)
  question QuestionnaireQuestion @relation(fields: [questionId], references: [id])

  @@unique([entryId, questionId])
  @@index([entryId])
  @@index([questionId])
}

// =====================================================================
// WASTE CERTIFICATE — Certificado de Coleta e Destinação de Resíduos
// Industriais. Generated client-side (pdf-lib), stored as a File, shared
// via a public link, then re-uploaded once physically signed.
// =====================================================================
model WasteCertificate {
  id           String                 @id @default(uuid())
  date         DateTime // issue date (header "Cambé, DD de Mês de AAAA")
  periodStart  DateTime
  periodEnd    DateTime
  description  String // e.g. "RESÍDUOS LIQUIDO CLASSE I"
  volume       String // e.g. "792L"
  status       WasteCertificateStatus @default(GENERATED)
  pdfFileId    String?
  signedFileId String?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  pdfFile    File? @relation("WASTE_CERTIFICATE_PDF", fields: [pdfFileId], references: [id])
  signedFile File? @relation("WASTE_CERTIFICATE_SIGNED", fields: [signedFileId], references: [id])

  @@index([status])
  @@index([createdAt])
}

enum WasteCertificateStatus {
  GENERATED // PDF generated, awaiting signed upload
  SIGNED // signed PDF uploaded
}

// =====================
