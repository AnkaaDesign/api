// =====================
// Financial / Billing
// =====================

model Invoice {
  id                  String                   @id @default(uuid())
  customerConfigId    String?                  @unique
  taskId              String?
  externalOperationId String?                  @unique
  customerId          String
  totalAmount         Decimal                  @db.Decimal(10, 2)
  paidAmount          Decimal                  @default(0) @db.Decimal(10, 2)
  status              InvoiceStatus            @default(DRAFT)
  notes               String?
  createdById         String?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  customerConfig      TaskQuoteCustomerConfig? @relation("InvoiceCustomerConfig", fields: [customerConfigId], references: [id], onDelete: Cascade)
  task                Task?                    @relation("TaskInvoiceEntities", fields: [taskId], references: [id], onDelete: Cascade)
  externalOperation   ExternalOperation?       @relation("ExternalOperationInvoice", fields: [externalOperationId], references: [id], onDelete: Cascade)
  customer            Customer                 @relation("CustomerInvoiceEntities", fields: [customerId], references: [id])
  createdBy           User?                    @relation("InvoicesCreated", fields: [createdById], references: [id])
  installments        Installment[]            @relation("InvoiceInstallments")
  nfseDocuments       NfseDocument[]           @relation("InvoiceNfse")

  @@index([taskId])
  @@index([customerId])
  @@index([status])
  @@index([createdById])
}

model Installment {
  id                  String                   @id @default(uuid())
  customerConfigId    String?
  externalOperationId String?
  invoiceId           String?
  number              Int
  dueDate             DateTime
  amount              Decimal                  @db.Decimal(10, 2)
  paidAmount          Decimal                  @default(0) @db.Decimal(10, 2)
  paidAt              DateTime?
  status              InstallmentStatus        @default(PENDING)
  paymentMethod       String?
  observations        String?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  customerConfig      TaskQuoteCustomerConfig? @relation("CustomerConfigInstallments", fields: [customerConfigId], references: [id], onDelete: Cascade)
  externalOperation   ExternalOperation?       @relation("ExternalOperationInstallments", fields: [externalOperationId], references: [id], onDelete: Cascade)
  invoice             Invoice?                 @relation("InvoiceInstallments", fields: [invoiceId], references: [id], onDelete: SetNull)
  bankSlip            BankSlip?                @relation("InstallmentBankSlip")
  receiptFiles        File[]                   @relation("InstallmentReceipts")

  @@unique([customerConfigId, number])
  @@unique([externalOperationId, number])
  @@index([customerConfigId])
  @@index([externalOperationId])
  @@index([invoiceId])
  @@index([dueDate])
  @@index([status])
}

model BankSlip {
  id                    String                @id @default(uuid())
  installmentId         String                @unique
  nossoNumero           String                @unique
  seuNumero             String?
  barcode               String?
  digitableLine         String?
  pixQrCode             String?
  txid                  String?
  type                  BankSlipType          @default(HIBRIDO)
  amount                Decimal               @db.Decimal(10, 2)
  dueDate               DateTime
  status                BankSlipStatus        @default(CREATING)
  sicrediStatus         String?
  pdfFileId             String?
  paidAmount            Decimal?              @db.Decimal(10, 2)
  paidAt                DateTime?
  liquidationData       Json?
  errorMessage          String?
  errorCount            Int                   @default(0)
  lastSyncAt            DateTime?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  installment           Installment           @relation("InstallmentBankSlip", fields: [installmentId], references: [id], onDelete: Cascade)
  pdfFile               File?                 @relation("BankSlipPdf", fields: [pdfFileId], references: [id])
  transactions          BankTransaction[]     @relation("BankSlipTransaction")
  reconciliationMatches ReconciliationMatch[] @relation("BankSlipMatches")

  @@index([nossoNumero])
  @@index([status])
  @@index([dueDate])
}

model NfseDocument {
  id            String     @id @default(uuid())
  invoiceId     String
  elotechNfseId Int?
  nfseNumber    Int?
  status        NfseStatus @default(PENDING)
  errorMessage  String?
  errorCount    Int        @default(0)
  retryAfter    DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  invoice Invoice @relation("InvoiceNfse", fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([elotechNfseId])
  @@index([status])
}

model SicrediToken {
  id               String    @id @default(uuid())
  accessToken      String
  refreshToken     String?
  tokenType        String    @default("Bearer")
  expiresIn        Int
  expiresAt        DateTime
  refreshExpiresIn Int?
  refreshExpiresAt DateTime?
  scope            String?
  identifier       String    @unique @default("default")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([expiresAt])
  @@index([identifier])
}

model SicrediWebhookEvent {
  id                    String             @id @default(uuid())
  idEventoWebhook       String             @unique
  nossoNumero           String
  movimento             String
  valorLiquidacao       Decimal?           @db.Decimal(10, 2)
  valorDesconto         Decimal?           @db.Decimal(10, 2)
  valorJuros            Decimal?           @db.Decimal(10, 2)
  valorMulta            Decimal?           @db.Decimal(10, 2)
  valorAbatimento       Decimal?           @db.Decimal(10, 2)
  dataEvento            DateTime?
  dataPrevisaoPagamento DateTime?
  agencia               String?
  posto                 String?
  beneficiario          String?
  carteira              String?
  rawPayload            Json
  status                WebhookEventStatus @default(RECEIVED)
  processedAt           DateTime?
  errorMessage          String?
  retryCount            Int                @default(0)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  @@index([nossoNumero])
  @@index([status])
  @@index([dataEvento])
}

